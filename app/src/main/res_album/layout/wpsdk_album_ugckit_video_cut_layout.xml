<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <com.skysoul.album.core.ugckit.cut.VideoPlayLayout
        android:id="@+id/wpsdk_album_video_play_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.skysoul.album.core.ugckit.cut.VideoCutLayout
        android:id="@+id/wpsdk_album_video_cut_layout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp" />

    <com.skysoul.album.core.ugckit.basic.TitleBarLayout
        android:id="@+id/wpsdk_album_titleBar_layout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:alpha="0.7"
        android:background="#000000" />

    <FrameLayout
        android:id="@+id/wpsdk_album_loading_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#44000000"
        android:visibility="gone"
        android:clickable="true">
        <ProgressBar
            style="@android:style/Widget.Holo.ProgressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center" />
    </FrameLayout>
</RelativeLayout>