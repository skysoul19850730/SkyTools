<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/album_head"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp">

            <TextView
                android:id="@+id/album_tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:padding="5dp"
                android:text="取消"
                android:layout_centerVertical="true"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="选择封面"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/_album_iv_crop"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:layout_toLeftOf="@+id/album_tvSave"
                android:padding="5dp"
                android:src="@drawable/album_ic_crop" />

            <TextView
                android:id="@+id/album_tvSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="15dp"
                android:background="@drawable/album_shape_finish"
                android:paddingHorizontal="15dp"
                android:paddingVertical="5dp"
                android:text="完成"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </RelativeLayout>
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/album_layout_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/album_cover_layout"
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="62dp">

        <com.skysoul.album.view.HorizontalListView
            android:id="@+id/album_coverList"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_gravity="center" />

        <SeekBar
            android:id="@+id/album_seekbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:max="100"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:progressDrawable="@null"
            android:thumb="@drawable/album_shape_seek_thumb" />
    </FrameLayout>

</LinearLayout>